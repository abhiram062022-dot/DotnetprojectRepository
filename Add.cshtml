@model WebApplication5.Models.StudentModel
@{
    ViewData["Title"] = "Student Details";
}

<div class="card shadow">
    <div class="card-header bg-primary text-white">
        <h5>Student Details</h5>
    </div>

    <div class="card-body">
        <form asp-action="Add" method="post">

            <input type="hidden" asp-for="Id" />

            <div class="row">

                <!-- LEFT SIDE -->
                <div class="col-md-6">

                    <!-- Name -->
                    <div class="form-group row mb-2">
                        <label class="col-md-4 col-form-label text-end">Name :</label>
                        <div class="col-md-8">
                            <input asp-for="Name" class="form-control form-control-sm" placeholder="Student Name" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>
                    </div>

                    <!-- Student Code -->
                    <div class="form-group row mb-2">
                        <label class="col-md-4 col-form-label text-end">Student Code :</label>
                        <div class="col-md-8">
                            <input asp-for="Code" class="form-control form-control-sm" placeholder="Student Code" />
                            <span asp-validation-for="Code" class="text-danger"></span>
                        </div>
                    </div>

                    <!-- Salary -->
                    <div class="form-group row mb-2">
                        <label class="col-md-4 col-form-label text-end">Salary :</label>
                        <div class="col-md-8">
                            <input asp-for="Salary" class="form-control form-control-sm" placeholder="Salary" />
                            <span asp-validation-for="Salary" class="text-danger"></span>
                        </div>
                    </div>

                </div>

                <!-- RIGHT SIDE -->
                <div class="col-md-6">

                    <!-- Phone -->
                    <div class="form-group row mb-2">
                        <label class="col-md-4 col-form-label text-end">Phone :</label>
                        <div class="col-md-8">
                            <input asp-for="PhoneNumber" class="form-control form-control-sm" placeholder="Phone Number" />
                            <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                        </div>
                    </div>

                    <!-- Gender -->
                    <div class="form-group row mb-2">
                        <label class="col-md-4 col-form-label text-end">Gender :</label>
                        <div class="col-md-8 d-flex align-items-center">

                            <div class="form-check me-3">
                                <input class="form-check-input" type="radio" asp-for="PhoneNumber" value="Male" />
                                <label class="form-check-label">Male</label>
                            </div>

                            <div class="form-check">
                                <input class="form-check-input" type="radio" asp-for="PhoneNumber" value="Female" />
                                <label class="form-check-label">Female</label>
                            </div>

                        </div>
                        <span asp-validation-for="PhoneNumber" class="text-danger offset-md-4 col-md-8"></span>
                    </div>

                    <!-- Department -->
                    <div class="form-group row mb-2">
                        <label class="col-md-4 col-form-label text-end">Department :</label>
                        <div class="col-md-8">
                            <select asp-for="PhoneNumber" class="form-select form-select-sm">
                                <option value="">Select Department</option>
                                <option value="CSE">CSE</option>
                                <option value="ECE">ECE</option>
                                <option value="MECH">MECH</option>
                            </select>
                            <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                        </div>
                    </div>

                </div>

            </div>
              
            <!-- BUTTONS -->
            <div class="row mt-4">
                <div class="col-md-12 offset-3">
                    <button id="button" type="button" class="btn btn-success me-2">Save</button>
                    <button type="reset" class="btn btn-danger me-2">Reset</button>
                    <button id="buttonsubmit" type="submit" hidden class="btn btn-primary">Submit</button>
                </div>
            </div>

        </form>
    </div>
</div>

<!-- Scripts -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="~/js/Student.js"></script>
